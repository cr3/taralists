# Required. Primary cert CN. Must match a live/<SERVER_HOSTNAME>/ directory
# under /etc/letsencrypt once the cert has been issued.
SERVER_HOSTNAME=lists.taram.ca

# Recommended. Space-separated compose service names to SIGHUP after each
# successful renewal.
RELOAD_SERVICES=nginx

# Timezone. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# (use the 'TZ identifier' column).
TZ=America/Toronto

# Mailman configuration. Set HYPERKITTY_API_KEY and SECRET_KEY to long random
# alphanumeric strings in your local .env (never commit them).
#HYPERKITTY_API_KEY=
#SECRET_KEY=
MAILMAN_ADMIN_USER=admin
MAILMAN_ADMIN_EMAIL=admin@example.com
#MAILMAN_ADMIN_PASSWORD=

# SQL database. Set DBPASS to a long random alphanumeric string (A-Za-z0-9)
# in your local .env (never commit it).
DBNAME=mailmandb
DBUSER=mailman
#DBPASS=

# HTTP/HTTPS bindings. Leave the *_BIND empty for IPv4-any; set to an IP to
# restrict. Do not use IP:PORT in HTTP(S)_BIND or HTTP(S)_PORT.
# Avoid ports 8081, 9081, 65510 (reserved by internal services).
HTTP_PORT=80
HTTP_BIND=
HTTPS_PORT=443
HTTPS_BIND=

# COMPOSE_PROJECT_NAME is set automatically by docker compose (defaults to the
# project directory name). Override it here only if you need a non-default
# name — docker-reload.py uses it to locate sibling containers.
#COMPOSE_PROJECT_NAME=taralists

# Internal IPv4 /24 subnet, format n.n.n (expands to n.n.n.0/24).
# Use a private range: https://en.wikipedia.org/wiki/Private_network#Private_IPv4_addresses
IPV4_NETWORK=172.22.6

# Optional. Use this IPv4 / IPv6 for outgoing connections (SNAT).
#SNAT_TO_SOURCE=
#SNAT6_TO_SOURCE=
